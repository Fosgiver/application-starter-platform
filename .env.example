# Application identity
APP_APP_NAME=Application Starter Platform
APP_APP_VERSION=0.1.0
APP_ENVIRONMENT=development
APP_DEBUG=false
APP_DOCS_ENABLED=true

# API server
APP_API_HOST=127.0.0.1
APP_API_PORT=8000
APP_OPEN_BROWSER_ON_START=true

# Database
# DATABASE_PROVIDER_URL_EXAMPLE
APP_DATABASE_URL=sqlite:///./application_starter_platform.db
APP_DATABASE_ECHO=false

# JWT authentication
APP_JWT_SECRET_KEY=
APP_JWT_ALGORITHM=HS256
APP_JWT_ACCESS_TOKEN_MINUTES=30
APP_JWT_ISSUER=application-starter-platform
APP_JWT_AUDIENCE=application-starter-platform-api

# Account policies
APP_SELF_REGISTRATION_ENABLED=true
APP_PASSWORD_MIN_LENGTH=8
APP_PASSWORD_MAX_LENGTH=128

# Security-token lifetimes
APP_EMAIL_VERIFICATION_TOKEN_MINUTES=1440
APP_PASSWORD_RESET_TOKEN_MINUTES=30

# Frontend destinations
APP_PUBLIC_BASE_URL=http://127.0.0.1:8000

# SMTP
APP_SMTP_ENABLED=false
# APP_SMTP_HOST=smtp.example.com
APP_SMTP_PORT=587
# APP_SMTP_USERNAME=
# APP_SMTP_PASSWORD=
# APP_SMTP_SENDER_EMAIL=
APP_SMTP_SENDER_NAME=Application Starter Platform
APP_SMTP_SECURITY=starttls